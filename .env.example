# ============================================================
# QuantumSafe — environment variables
# Copy to `.env` (in backend/ or repo root) and fill in.
# Never commit your real .env.
# ============================================================

# --- Core ---------------------------------------------------
# Flask session/signing secret. Generate: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
# JWT signing key (separate from SECRET_KEY). Generate the same way.
JWT_SECRET_KEY=

# --- Database -----------------------------------------------
# Dev default is SQLite (sqlite:///quantumsafe.db). For production use Postgres:
# postgresql://user:password@host:5432/dbname   (Render provides this URL)
DATABASE_URL=

# --- CORS / URLs --------------------------------------------
# Comma-separated allowed dashboard origin(s) for the API.
FRONTEND_ORIGIN=http://localhost:3000
# Public URL of the deployed dashboard (used in emails).
DASHBOARD_URL=http://localhost:3000
# Public URL of this API (used to build email verification links).
API_URL=http://localhost:5000

# --- Email (SMTP, for verification + password reset) --------
# Leave MAIL_SERVER blank in dev to print emails to the server log instead.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@quantumsafe.dev

# --- Rate limiting (optional) -------------------------------
# Dev default is in-memory. For production set a Redis URL:
# redis://default:password@host:6379
RATELIMIT_STORAGE_URI=memory://
